# Example environment variables for Charles MCP Server
# Copy this file to .env and adjust values for your local environment.

# Charles Web Interface credentials
CHARLES_USER=tower
CHARLES_PASS=123456

# Charles proxy connection
CHARLES_PROXY_HOST=127.0.0.1
CHARLES_PROXY_PORT=8888

# Optional explicit config path
# CHARLES_CONFIG_PATH=C:\Users\Administrator\AppData\Local\Packages\XK72.Charles_xxx\RoamingState\charles.config

# Timeouts and limits
CHARLES_REQUEST_TIMEOUT=10
CHARLES_MAX_STOPTIME=3600
